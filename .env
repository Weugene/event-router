APP_NAME=event-router
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000
APP_TIMEOUT_SECONDS=10
LOG_LEVEL=INFO

# Only for docker-compose
POSTGRES_HOST=postgres
# Only for local development
# POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=event_router
POSTGRES_USER=event_router
POSTGRES_PASSWORD=event_router
POSTGRES_MIN_POOL_SIZE=1
POSTGRES_MAX_POOL_SIZE=5
